generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Store {
  id          String @id @default(cuid())
  shop        String @unique
  accessToken String?
  grantedScopes String? @map("scope")
  tokenAcquisitionMode String? @default("offline_expiring")
  isOffline   Boolean @default(true)
  installedAt DateTime?
  reauthorizedAt DateTime?
  webhooksRegisteredAt DateTime?
  lastWebhookRegistrationStatus String?
  lastConnectionCheckAt DateTime?
  lastConnectionStatus String?
  lastConnectionError String?
  authErrorCode String?
  authErrorMessage String?
  accessTokenExpiresAt DateTime?
  refreshToken String?
  refreshTokenExpiresAt DateTime?
  uninstalledAt DateTime?
  lastSyncAt DateTime?
  lastSyncStatus String? @map("syncStatus")
  onboardingCompletedAt DateTime?
  onboardingDismissedAt DateTime?
  onboardingSelectedModule String?
  onboardingFirstInsightViewedAt DateTime?
  onboardingPlanConfirmedAt DateTime?

  trialStartedAt DateTime?
  trialEndsAt    DateTime?

  fraudSensitivity   String  @default("medium")
  sharedFraudNetwork Boolean @default(false)
  pricingBias        Int     @default(55)
  profitGuardrail    Int     @default(18)

  subscription StoreSubscription? @relation("StoreToSubscription")

  competitorDomains CompetitorDomain[]
  productSnapshots  ProductSnapshot[]
  orders            Order[]
  customers         Customer[]
  fraudSignals      FraudSignal[]
  competitorData    CompetitorData[]
  priceHistory      PriceHistory[]
  profitData        ProfitOptimizationData[]
  billingAuditLogs  BillingAuditLog[]
  billingPlanIntents BillingPlanIntent[]
  timelineEvents    TimelineEvent[]
  syncJobs          SyncJob[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProductSnapshot {
  id               String   @id @default(cuid())
  store            Store    @relation(fields: [storeId], references: [id])
  storeId          String
  shopifyProductId String
  handle           String
  title            String
  status           String   @default("active")
  variantCount     Int      @default(0)
  currentPrice     Float?
  currency         String?
  syncedAt         DateTime @default(now())
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  variants VariantSnapshot[]

  @@unique([storeId, shopifyProductId])
  @@index([storeId, handle])
}

model VariantSnapshot {
  id               String          @id @default(cuid())
  product          ProductSnapshot @relation(fields: [productSnapshotId], references: [id], onDelete: Cascade)
  productSnapshotId String
  shopifyVariantId String
  title            String
  price            Float
  currency         String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([productSnapshotId, shopifyVariantId])
}

model SubscriptionPlan {
  id        String   @id @default(cuid())
  name      String   @unique
  price     Float
  trialDays Int      @default(3)
  features  String // JSON string describing enabled modules
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  subscriptions StoreSubscription[]
}

model StoreSubscription {
  id              String           @id @default(cuid())
  store           Store            @relation("StoreToSubscription", fields: [storeId], references: [id])
  storeId         String           @unique
  plan            SubscriptionPlan @relation(fields: [planId], references: [id])
  planId          String
  starterModule   String?
  shopifyChargeId String? // link to Shopify Billing
  active          Boolean          @default(true)
  billingStatus   String           @default("ACTIVE")
  startedAt       DateTime         @default(now())
  planActivatedAt DateTime         @default(now())
  cancelledAt     DateTime?
  endsAt          DateTime?
  lastBillingSyncAt DateTime?
  lastBillingWebhookProcessedAt DateTime?
  lastBillingResolutionSource String?
  lastBillingSubscriptionName String?
  moduleSwitchedAt  DateTime?

  auditLogs BillingAuditLog[]
}

model BillingAuditLog {
  id                  String             @id @default(cuid())
  store               Store              @relation(fields: [storeId], references: [id])
  storeId             String
  subscription        StoreSubscription? @relation(fields: [subscriptionId], references: [id])
  subscriptionId      String?
  eventType           String
  previousPlanName    String?
  nextPlanName        String?
  previousStarterModule String?
  nextStarterModule   String?
  billingStatus       String?
  metadataJson        String?
  createdAt           DateTime           @default(now())
}

model BillingPlanIntent {
  id                   String   @id @default(cuid())
  store                Store    @relation(fields: [storeId], references: [id])
  storeId              String
  requestedPlanName    String
  requestedStarterModule String?
  actionType           String
  status               String   @default("CREATING")
  confirmationUrl      String?
  shopifyChargeId      String?
  host                 String?
  returnPath           String?
  errorCode            String?
  errorMessage         String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  confirmedAt          DateTime?
  cancelledAt          DateTime?
  expiresAt            DateTime?

  @@index([storeId, status, createdAt])
}

model Customer {
  id                 String   @id @default(cuid())
  store              Store    @relation(fields: [storeId], references: [id])
  storeId            String
  shopifyCustomerId  String
  email              String?
  totalOrders        Int      @default(0)
  totalRefunds       Int      @default(0)
  refundRate         Float    @default(0)
  fraudSignalsCount  Int      @default(0)
  paymentReliability Float    @default(0)
  creditScore        Int      @default(50)
  creditCategory     String   @default("Normal Buyer")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  orders       Order[]
  fraudSignals FraudSignal[]
  timelineEvents TimelineEvent[]
}

model Order {
  id              String    @id @default(cuid())
  store           Store     @relation(fields: [storeId], references: [id])
  storeId         String
  customer        Customer? @relation(fields: [customerId], references: [id])
  customerId      String?
  shopifyOrderId  String    @unique
  shopifyOrderGid String?
  shopifyLegacyOrderId String?
  orderName       String?
  totalAmount     Float
  currency        String
  fraudScore      Int       @default(0)
  fraudRiskLevel  String    @default("Low")
  refundRequested Boolean   @default(false)
  refunded        Boolean   @default(false)
  status          String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  fraudSignals FraudSignal[]
  timelineEvents TimelineEvent[]

  @@index([shopifyOrderGid])
  @@index([storeId, shopifyLegacyOrderId])
  @@index([storeId, orderName])
}

model FraudSignal {
  id         String    @id @default(cuid())
  store      Store     @relation(fields: [storeId], references: [id])
  storeId    String
  order      Order?    @relation(fields: [orderId], references: [id])
  orderId    String?
  customer   Customer? @relation(fields: [customerId], references: [id])
  customerId String?

  ipAddress          String?
  email              String?
  shippingAddress    String?
  deviceFingerprint  String?
  paymentFingerprint String?
  refundHistory      String?
  orderFrequency     String?

  riskScore         Int     @default(0)
  riskLevel         String  @default("Low")
  sharedNetworkHash String?

  createdAt DateTime @default(now())
}

model CompetitorDomain {
  id        String   @id @default(cuid())
  store     Store    @relation(fields: [storeId], references: [id])
  storeId   String
  domain    String
  label     String?
  createdAt DateTime @default(now())
}

model CompetitorData {
  id             String   @id @default(cuid())
  store          Store    @relation(fields: [storeId], references: [id])
  storeId        String
  productHandle  String
  competitorName String
  competitorUrl  String
  source         String // website | google_shopping | meta_ads
  price          Float?
  promotion      String?
  stockStatus    String?
  adCopy         String?
  insightsJson   String? // AI-generated insights
  collectedAt    DateTime @default(now())
}

model PriceHistory {
  id                  String   @id @default(cuid())
  store               Store    @relation(fields: [storeId], references: [id])
  storeId             String
  productHandle       String
  currentPrice        Float
  recommendedPrice    Float
  expectedMarginDelta Float
  expectedProfitGain  Float?
  rationaleJson       String? // AI explanation
  createdAt           DateTime @default(now())
}

model ProfitOptimizationData {
  id                      String   @id @default(cuid())
  store                   Store    @relation(fields: [storeId], references: [id])
  storeId                 String
  productHandle           String
  productCost             Float
  sellingPrice            Float
  competitorAveragePrice  Float?
  advertisingSpend        Float?
  shippingCost            Float?
  returnRate              Float?
  salesVelocity           Float?
  optimalPrice            Float?
  projectedMarginIncrease Float?
  projectedMonthlyProfit  Float?
  bundleSuggestionsJson   String?
  discountStrategyJson    String?
  createdAt               DateTime @default(now())
}

model TimelineEvent {
  id           String    @id @default(cuid())
  store        Store     @relation(fields: [storeId], references: [id])
  storeId      String
  customer     Customer? @relation(fields: [customerId], references: [id])
  customerId   String?
  order        Order?    @relation(fields: [orderId], references: [id])
  orderId      String?
  category     String
  eventType    String
  title        String
  detail       String
  severity     String    @default("info")
  scoreImpact  Int?
  metadataJson String?
  createdAt    DateTime  @default(now())

  @@index([storeId, createdAt])
  @@index([customerId, createdAt])
}

model SyncJob {
  id           String   @id @default(cuid())
  store        Store    @relation(fields: [storeId], references: [id])
  storeId      String
  jobType      String
  triggerSource String
  status       String   @default("PENDING")
  summaryJson  String?
  errorMessage String?
  startedAt    DateTime?
  finishedAt   DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([storeId, createdAt])
  @@index([status, createdAt])
}
